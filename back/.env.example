# ============================================================================
# EXAMPLE .env FILE - DO NOT COMMIT REAL SECRETS
# ============================================================================
# Copy this file to .env and fill in your actual values.
# Este arquivo documenta TODAS as variáveis disponíveis.
# Para um .env mínimo, veja o arquivo .env criado.

# ============================================================================
# 🔐 SEGURANÇA (OBRIGATÓRIO)
# ============================================================================
SECRET_KEY=
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_MINUTES=10080

# ============================================================================
# 🔧 DESENVOLVIMENTO (OPCIONAL)
# ============================================================================
# DEV_MODE: Ativa modo desenvolvimento (responde apenas para DEV_PHONE_NUMBERS)
# DEV_PHONE_NUMBERS: Números separados por vírgula (sem @c.us)
DEV_MODE=false
DEV_PHONE_NUMBERS=

# Logging (valores padrão já são adequados)
# ENVIRONMENT=development
# LOG_LEVEL=INFO
# LOG_COLOR=true

# ============================================================================
# 💾 DATABASE (Configurado pelo Docker Compose)
# ============================================================================
# Para Docker Compose (padrão):
# DATABASE_URL=postgresql+psycopg2://dba:dba@db:5432/BotDB
#
# Para conexão local (fora do Docker):
# DATABASE_URL=postgresql+psycopg2://dba:dba@localhost:15432/BotDB

# ============================================================================
# 🗄️ REDIS (Configurado pelo Docker Compose)
# ============================================================================
# Para Docker Compose (padrão):
# REDIS_URL=redis://redis:6379/0
#
# Para conexão local (fora do Docker):
# REDIS_URL=redis://localhost:6379/0
#
# Configurações avançadas (defaults são adequados):
# REDIS_CACHE_TTL=3600
# REDIS_MAX_CONNECTIONS=10

# ============================================================================
# 🤖 LLM PROVIDERS
# ============================================================================
# Configuração de provider (defaults são adequados)
# LLM_PRIMARY_PROVIDER=groq
# LLM_ENABLE_FALLBACK=true
# LLM_TIMEOUT=60

# ----------------------------------------------------------------------------
# GROQ AI (Recomendado - rápido e tier gratuito generoso)
# ----------------------------------------------------------------------------
# Obtenha em: https://console.groq.com/
GROQ_API_KEY=
# GROQ_MODEL=llama-3.3-70b-versatile
# GROQ_MAX_TOKENS=2048
# GROQ_TEMPERATURE=0.7

# ----------------------------------------------------------------------------
# GEMINI AI (OBRIGATÓRIO - fallback)
# ----------------------------------------------------------------------------
# Obtenha em: https://ai.google.dev/
GOOGLE_API_KEY=
# GEMINI_MODEL=gemini-1.5-pro
# GEMINI_MAX_TOKENS=2048
# GEMINI_TEMPERATURE=0.7

# ============================================================================
# 💬 WAHA (WhatsApp HTTP API)
# ============================================================================
# URLs (configuradas pelo Docker Compose)
# WAHA_URL=http://waha:3000
# WAHA_SESSION_NAME=default
# WAHA_WEBHOOK_URL=http://api:3333/api/v1/webhooks/waha

# Autenticação (OBRIGATÓRIO)
WAHA_API_KEY=
WAHA_DASHBOARD_USERNAME=admin
WAHA_DASHBOARD_PASSWORD=
WHATSAPP_SWAGGER_USERNAME=admin
WHATSAPP_SWAGGER_PASSWORD=

# Anti-ban (defaults são adequados)
# WAHA_ANTI_BAN_ENABLED=true
# WAHA_MIN_DELAY_SECONDS=3
# WAHA_MAX_DELAY_SECONDS=8
# WAHA_MESSAGES_PER_HOUR=30
# WAHA_POLLING_INTERVAL=10
# MESSAGE_DEBOUNCE_SECONDS=2

# Mock (apenas para testes)
# WAHA_MOCK_REQUESTS=false

# ============================================================================
# 🏥 INFORMAÇÕES DA CLÍNICA (Já configurado no código)
# ============================================================================
# Valores padrão já estão corretos para Clínica Go
# Só altere se necessário
# CLINIC_NAME=Clínica Go
# CLINIC_ADDRESS=Av. São Miguel, 1000 - sala 102 - Centro, Dois Irmãos - RS, 93950-000
# CLINIC_LATITUDE=-29.5838212
# CLINIC_LONGITUDE=-51.0869905
# CLINIC_MAPS_URL=https://www.google.com/maps/place/Av.+S%C3%A3o+Miguel,+1000+-+sala+102

# ============================================================================
# 📊 CHROMADB (Defaults são adequados)
# ============================================================================
# CHROMA_PERSIST_DIR=./data/chroma
# CHROMA_COLLECTION_NAME=conversations

# ============================================================================
# ⚙️ REDIS QUEUE (RQ) - Defaults são adequados
# ============================================================================
# Timeouts (segundos)
# RQ_JOB_TIMEOUT_MESSAGE=300
# RQ_JOB_TIMEOUT_AI=60
# RQ_JOB_TIMEOUT_ESCALATION=30
# RQ_MAX_RETRIES=3
# RQ_DEFAULT_RESULT_TTL=500
# RQ_DEFAULT_FAILURE_TTL=86400
# RQ_FAILED_QUEUE_NAME=failed

# ============================================================================
# 📈 AUTOSCALER - Defaults são adequados
# ============================================================================
# AUTOSCALER_MIN_WORKERS=3
# AUTOSCALER_MAX_WORKERS=5
# AUTOSCALER_SCALE_UP_THRESHOLD=5
# AUTOSCALER_SCALE_DOWN_THRESHOLD=0
# AUTOSCALER_IDLE_TIME_THRESHOLD=300

# ============================================================================
# 📊 ANALYTICS - Defaults são adequados
# ============================================================================
# Performance Thresholds
# ANALYTICS_LATENCY_THRESHOLD_MS=5000
# ANALYTICS_ERROR_RATE_THRESHOLD=5.0
# ANALYTICS_REALTIME_WINDOW_MINUTES=5
# ANALYTICS_ACTIVE_CONVERSATIONS_WARNING=50
# ANALYTICS_ACTIVE_CONVERSATIONS_CRITICAL=100

# Cache TTL (segundos)
# ANALYTICS_CACHE_TTL_REALTIME=30
# ANALYTICS_CACHE_TTL_METRICS=900
# ANALYTICS_CACHE_TTL_HISTORICAL=3600
# ANALYTICS_CACHE_TTL_REPORTS=1800

# ============================================================================
# 🔌 WEBSOCKET - Defaults são adequados
# ============================================================================
# WEBSOCKET_MAX_CONNECTIONS_PER_USER=3
# WEBSOCKET_MESSAGE_RATE_LIMIT=10
# WEBSOCKET_IDLE_TIMEOUT_MINUTES=30

# ============================================================================
# 📧 SMTP (Configurado pelo Docker Compose para Maildev)
# ============================================================================
# Para desenvolvimento com Maildev (padrão):
# SMTP_HOST=maildev
# SMTP_PORT=1025
# SMTP_TLS=false
# SMTP_SENDER=no-reply@clinicago.local
# SMTP_USERNAME=
# SMTP_PASSWORD=

# Para produção (configure seu servidor SMTP):
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_TLS=true
# SMTP_SENDER=seu-email@gmail.com
# SMTP_USERNAME=seu-email@gmail.com
# SMTP_PASSWORD=sua-senha-de-app

# ============================================================================
# 🌐 CORS & COOKIES - Defaults são adequados
# ============================================================================
# CORS_ORIGINS=["http://localhost:3000"]
# CORS_CREDENTIALS=true
# COOKIE_HTTPONLY=true
# COOKIE_SECURE=false
# COOKIE_SAMESITE=lax
# COOKIE_DOMAIN=

# ============================================================================
# ✉️ EMAIL VERIFICATION - Defaults são adequados
# ============================================================================
# EMAIL_VERIFICATION_TOKEN_EXPIRATION_HOURS=24
# EMAIL_VERIFICATION_RESEND_MIN_INTERVAL_MINUTES=5
# FRONTEND_URL=http://localhost:3000

# ============================================================================
# 📝 PROMPTS - Default é adequado
# ============================================================================
# PROMPTS_PATH=src/robbot/config/prompts.yaml
